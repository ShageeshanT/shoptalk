# ShopTalk Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- AI Provider ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
DATABASE_URL=sqlite:///./shoptalk.db
# DATABASE_URL=postgresql+psycopg2://user:password@db:5432/shoptalk

# --- API Security ---
SECRET_KEY=change-me-in-production
SELLER_API_KEY=

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# --- WhatsApp Business API (Phase 5) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Telegram Bot (Phase 4) ---
TELEGRAM_BOT_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
